// One billion iterations of a multiply + add + modulo — pure integer ALU.
// s = sum(i*i) mod 1_000_000_007 for i in 1..=1_000_000_000.
func main() {
    n := 1000000000
    md := 1000000007
    s := 0
    i := 1
    while i <= n {
        s = (s + i*i) % md
        i = i + 1
    }
    println(s)
}
