// The canonical textbook data race: 4 goroutines increment a shared global
// counter with no synchronization. Expected sum: 8,000,000.
var counter = 0

func incr() {
	i := 0
	for i < 2000000 {
		counter = counter + 1
		i = i + 1
	}
}

func main() {
	go incr()
	go incr()
	go incr()
	go incr()
	sleep(500)
	println(str(counter))
}
