// machin-game-demo-raycaster — ASCII Wolfenstein-style raycaster.
//
// Build and run:
//   machin encode src/main.src > app.mfl && machin build app.mfl -o app && ./app
//
// Controls: W=forward S=backward A=turn left D=turn right Q=quit

var SCR_W = 80
var SCR_H = 24

var scr = []string{}

func scr_init() {
    scr = []string{}
    i := 0
    while i < SCR_W * SCR_H {
        scr = append(scr, " ")
        i = i + 1
    }
}

func scr_cls() {
    i := 0
    while i < SCR_W * SCR_H {
        scr[i] = " "
        i = i + 1
    }
}

func scr_put(x, y, c) {
    if x >= 0 && x < SCR_W && y >= 0 && y < SCR_H {
        scr[y * SCR_W + x] = c
    }
}

func scr_text(x, y, s) {
    i := 0
    while i < len(s) {
        scr_put(x + i, y, charat(s, i))
        i = i + 1
    }
}

func scr_frame(ESC) (f) {
    f = ESC + "[H"
    y := 0
    while y < SCR_H {
        x := 0
        while x < SCR_W {
            f = f + scr[y * SCR_W + x]
            x = x + 1
        }
        f = f + "\n"
        y = y + 1
    }
}

