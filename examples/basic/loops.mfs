// loops.mfs — while loops: a running sum and a countdown.

func main() {
    // sum 1..10
    sum := 0
    i := 1
    while i <= 10 {
        sum = sum + i
        i = i + 1
    }
    println("sum 1..10 =", sum)

    // countdown
    n := 5
    while n > 0 {
        print(n, "")
        n = n - 1
    }
    println("liftoff")
}
