// variables.mfs — declaration (:=), reassignment (=), and var.

func main() {
    x := 10        // declare
    var y = 5      // declare with var
    x = x + y      // reassign
    name := "machin"
    flag := x > y && y > 0
    println("x =", x)
    println("y =", y)
    println("name =", name, "len =", len(name))
    println("flag =", flag)
}
