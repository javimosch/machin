func main(){url:="https://example.com/" status,body,err:=http_get(url)if len(err)>0{println("http_get error: "+err)exit(1)}println("http_get "+url+" -> "+str(status)+" ("+str(len(body))+" bytes)")token:="demo-token" apiurl:="https://httpbin.org/get" status2,body2,err2:=http_request("GET",apiurl,[]string{"Authorization: Bearer "+token,"Accept: application/json"},"")if len(err2)>0{println("http_request error: "+err2)exit(1)}println("http_request "+apiurl+" -> "+str(status2)+" ("+str(len(body2))+" bytes)")}
