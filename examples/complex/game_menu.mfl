func run_settings(sound){println("")println("--- SETTINGS ---")println("sound is currently:",sound)print("toggle sound? (y/n) > ")ans:=trim(to_lower(input()))if ans=="y"{if sound=="on"{println("sound -> off")return "off"}println("sound -> on")return "on"}println("(unchanged)")return sound}

func main(){sound:="on" running:=true while running{println("")println("=== GAME MENU ===")println("1) Start")println("2) Settings")println("3) Exit")print("> ")choice:=trim(to_lower(input()))if choice==""{println("")println("(eof) Bye!")running=false}else if choice=="1"||choice=="start"{println("Starting game... loading level 1!")}else if choice=="2"||choice=="settings"{sound=run_settings(sound)}else if choice=="3"||choice=="exit"{println("Bye!")running=false}else{println("unknown option:",choice)}}}
