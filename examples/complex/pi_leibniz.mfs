// pi_leibniz.mfs — approximate pi with the Leibniz series (float arithmetic).
// pi = 4 * (1 - 1/3 + 1/5 - 1/7 + ...)

func pi_approx(terms) {
    sum := 0.0
    sign := 1.0
    k := 0
    while k < terms {
        sum = sum + sign / (2.0 * k + 1.0)
        sign = -sign
        k = k + 1
    }
    return 4.0 * sum
}

func main() {
    println("pi ~", pi_approx(10))
    println("pi ~", pi_approx(1000))
    println("pi ~", pi_approx(100000))
}
