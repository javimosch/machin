func main(){ts:=time_make(2026,6,23,9,30,0)println("built timestamp: "+str(ts))println("formatted:        "+time_format(ts,"%Y-%m-%d %H:%M:%S %A"))f:=time_fields(ts)println("fields [y,mo,d,h,mi,s,wday,yday]: "+str(f[0])+"-"+str(f[1])+"-"+str(f[2])+" "+str(f[3])+":"+str(f[4])+":"+str(f[5])+" wday="+str(f[6])+" yday="+str(f[7]))round:=time_make(f[0],f[1],f[2],f[3],f[4],f[5])println("round-trip ok: "+str(round==ts))println("note: time_make/time_format/time_fields all operate in local time — output depends on $TZ (set TZ=UTC for deterministic results)")}
