func main(){s:="Hello, MFL! <binary> & special chars"enc:=base64_encode(s)println("original: ",s)println("encoded:  ",enc)dec:=base64_decode(enc)println("decoded:  ",dec)println("round-trip ok:",dec==s)url_safe:="SGVsbG8sIE1GTCEgPGJpbmFyeT4gJiBzcGVjaWFsIGNoYXJz"dec2:=base64_decode(url_safe)println("url-safe decode:",dec2)no_pad:="SGVsbG8"dec3:=base64_decode(no_pad)println("no-padding decode:",dec3)}