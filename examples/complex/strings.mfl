func main() { s := "Hello, Machine World" println("len:", len(s)) println("upper:", to_upper(s)) println("lower:", to_lower(s)) println("substr(7,14):", substr(s, 7, 14)) println("index 'Machine':", index(s, "Machine"), "index 'xyz':", index(s, "xyz")) println("contains 'World':", contains(s, "World"), "prefix 'Hello':", has_prefix(s, "Hello"), "suffix 'World':", has_suffix(s, "World")) println("charat(0):", charat(s, 0)) println("replace:", replace(s, "Machine", "MFL")) println("trim:", "[" + trim("   spaced   ") + "]") parts := split("a,b,c,d", ",") println("split count:", len(parts), "parts[2]:", parts[2]) println("join:", join(parts, "-")) line := "GET /users/42 HTTP/1.1" fields := split(line, " ") println("method:", fields[0], "path:", fields[1]) seg := split(fields[1], "/") println("resource:", seg[1], "id:", seg[2]) }

