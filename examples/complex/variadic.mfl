func sum(nums...){total:=0 for _,n:=range nums{total=total+n}return total}

func labeled(label,vals...){out:=label+":" for _,v:=range vals{out=out+" "+str(v)}return out}

func main(){println("sum() =",sum())println("sum(1,2,3) =",sum(1,2,3))println("sum(10,20,30,40) =",sum(10,20,30,40))xs:=[]int{5,6,7}println("sum(xs...) =",sum(xs...))println(labeled("nums",1,2,3))println(labeled("empty"))println(sum_strings("a","b","c"))}

func sum_strings(parts...){s:="" for _,p:=range parts{s=s+p}return s}
