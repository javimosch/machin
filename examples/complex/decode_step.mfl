// The non-matmul half of a quantized-LLM decode step, in pure MFL.
//
// The quantized matrix-vector products (embedding, attention, FFN) are the
// dot_q8 / dot_i8 kernels. Around them every transformer decode step needs
// three small elementwise kernels: RMS normalization before each block,
// softmax over the attention scores and the final logits, and an argmax to
// pick the greedy next token. None of those are matmuls, so they live here as
// ordinary MFL loops over raw fp32 buffers (alloc + poke_f32 / peek_f32) — the
// same zero-copy buffers dot_q8 reads, no slices, no per-element call overhead.

// rmsnorm: y[i] = x[i] / sqrt(mean(x^2) + eps) * w[i]  (Llama-style, no mean
// subtraction). x, w and dst are n-float fp32 buffers; dst may alias x.
func rmsnorm(dst, x, w, n, eps) {
	ss := 0.0
	i := 0
	while i < n {
		v := peek_f32(x, i * 4)
		ss = ss + v * v
		i = i + 1
	}
	inv := 1.0 / sqrt(ss / float(n) + eps)
	i = 0
	while i < n {
		poke_f32(dst, i * 4, peek_f32(x, i * 4) * inv * peek_f32(w, i * 4))
		i = i + 1
	}
}

// softmax, in place and numerically stable: subtract the max before exp so a
// large logit can't overflow. x is an n-float fp32 buffer.
func softmax(x, n) {
	m := peek_f32(x, 0)
	i := 1
	while i < n {
		v := peek_f32(x, i * 4)
		if v > m { m = v }
		i = i + 1
	}
	sum := 0.0
	i = 0
	while i < n {
		e := exp(peek_f32(x, i * 4) - m)
		poke_f32(x, i * 4, e)
		sum = sum + e
		i = i + 1
	}
	i = 0
	while i < n {
		poke_f32(x, i * 4, peek_f32(x, i * 4) / sum)
		i = i + 1
	}
}

// argmax: index of the largest fp32 in an n-float buffer — greedy sampling.
func argmax(x, n)(best) {
	best = 0
	bv := peek_f32(x, 0)
	i := 1
	while i < n {
		v := peek_f32(x, i * 4)
		if v > bv { bv = v  best = i }
		i = i + 1
	}
	return
}

// fill an n-float buffer from a []float literal, returning the buffer pointer.
func to_buf(vals, n)(p) {
	p = alloc(n * 4)
	i := 0
	while i < n {
		poke_f32(p, i * 4, vals[i])
		i = i + 1
	}
	return
}

func main() {
	// A hidden state going into an attention block, and the block's learned
	// RMSNorm weights: normalize before projecting to Q/K/V.
	n := 4
	h := to_buf([]float{1.0, 2.0, 3.0, 4.0}, n)
	w := to_buf([]float{1.0, 1.0, 1.0, 1.0}, n)
	rmsnorm(h, h, w, n, 0.00001)
	line := "rmsnorm:"
	i := 0
	while i < n {
		line = line + " " + str(peek_f32(h, i * 4))
		i = i + 1
	}
	println(line)

	// The model's output logits over a 4-token vocab for this position.
	// softmax -> probabilities, argmax -> the greedy next token.
	logits := to_buf([]float{1.0, 3.0, 2.0, 0.0}, n)
	tok := argmax(logits, n)
	softmax(logits, n)
	println("greedy token:", tok, "p:", peek_f32(logits, tok * 4))
	line = "probs:"
	i = 0
	while i < n {
		line = line + " " + str(peek_f32(logits, i * 4))
		i = i + 1
	}
	println(line)

	free(h)
	free(w)
	free(logits)
}
