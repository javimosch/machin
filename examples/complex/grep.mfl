func main(){lines:=[]string{"alice:42:admin","bob:not_a_number:user","carol:99:admin"}pattern:="[0-9]+"i:=0 for i<len(lines){line:=lines[i]if regex_match(line,pattern){println("match:",line,"-> first number:",regex_find(line,pattern))}else{println("no match:",line)}i=i+1}groups:=regex_groups("carol:99:admin","([a-z]+):([0-9]+):([a-z]+)")println("groups whole:",groups[0],"name:",groups[1],"id:",groups[2],"role:",groups[3])println("replace all digits:",regex_replace("alice:42:admin","[0-9]+","#"))println("invalid pattern is a silent no-op, not an error:")println("  match ->",regex_match("abc","("),"find ->",regex_find("abc","("),"replace ->",regex_replace("abc","(","X"))println("replace repl is literal, no \\1 backreferences:",regex_replace("2024-01-02","([0-9]+)-([0-9]+)-([0-9]+)","$1"))}
