func main(){raw:="hello world & goodbye=world/foo+bar" encoded:=url_encode(raw)println("raw:    ",raw)println("encoded:",encoded)decoded:=url_decode(encoded)println("decoded:",decoded)println("round-trip ok:",decoded==raw)plus:=url_decode("hello+world")println("plus->space: '"+plus+"'")bad:=url_decode("bad%GGseq")println("bad %XX passthrough:",bad)}
