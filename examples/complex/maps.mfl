func main(){words:=[]string{"go","map","go","chan","map","go","slice"}freq:=make(map[string]int)i:=0 for i<len(words){w:=words[i]freq[w]=freq[w]+1 i=i+1}println("go:",freq["go"],"map:",freq["map"],"chan:",freq["chan"],"slice:",freq["slice"])println("distinct words:",len(freq),"seen 'list'?",has(freq,"list"))ks:=keys(freq)total:=0 j:=0 for j<len(ks){total=total+freq[ks[j]]j=j+1}println("total words counted:",total)roman:=make(map[int]string)roman[1]="I" roman[5]="V" roman[10]="X" println("5 ->",roman[5],"| 99 ->",roman[99])}
