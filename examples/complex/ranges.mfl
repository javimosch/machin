func main(){nums:=[]int{5,10,15,20}sum:=0 for i,v:=range nums{println("nums[",i,"] =",v)sum=sum+v}println("sum:",sum)vowels:=0 for i,c:=range "machine first"{if c=="a"||c=="e"||c=="i"||c=="o"||c=="u"{vowels=vowels+1 println("vowel at",i,":",c)}}println("vowels:",vowels)prices:=make(map[string]int)prices["apple"]=3 prices["bread"]=2 prices["milk"]=4 bill:=0 for item,price:=range prices{println(item,"costs",price)bill=bill+price}println("total bill:",bill)}
