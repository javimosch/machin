    if name == "peek_f32" { s = "mfl_peek_f32"  return s }
    if name == "peek_i32" { s = "mfl_peek_i32"  return s }
    if name == "peek_i8" { s = "mfl_peek_i8"  return s }
    if name == "peek_u8" { s = "mfl_peek_u8"  return s }
    if name == "dot_i8" { s = "mfl_dot_i8"  return s }
    if name == "ptr_str" { s = "mfl_ptr_str"  return s }
    if name == "dial" { s = "mfl_dial"  return s }
    if name == "listen" { s = "mfl_listen"  return s }
    if name == "accept" { s = "mfl_accept"  return s }
    if name == "peer_addr" { s = "mfl_peer_addr"  return s }
    if name == "socket_timeout" { s = "mfl_socket_timeout"  return s }
    if name == "read" { s = "mfl_read"  return s }
    if name == "read_bytes" { s = "mfl_read_bytes"  return s }
    if name == "write" { s = "mfl_write"  return s }
    if name == "input" { s = "mfl_input"  return s }
    if name == "read_stdin" { s = "mfl_read_stdin"  return s }
    if name == "args" { s = "mfl_args"  return s }
    if name == "env" { s = "mfl_env"  return s }
