// selfhost/cgbuiltin.src — Stage 4 codegen, sub-slice (4c): the builtin C table
// (port of callBody's builtin switch), printCall, and multiAssign. In bodyOnly mode
// the uses<X> flags gate the SKIPPED runtime prelude, so they don't affect output and
// are omitted here. json/parse (per-type serializers), extern FFI calls, and multi-
// return builtins are deferred to slice 4d -> g_cg_unsup so the harness skips them.

var g_cg_unsup = 0

// Feature-usage flags, set as builtins are emitted (mirrors Go's uses<X>). They gate
// which runtime prelude blocks emit_prelude_gated includes — PRECISELY, by builtin name,
// not by scanning the body text (a user func named `noise_x` must NOT pull the Perlin
// runtime). Reset per compile.
var g_uses_math = 0
var g_uses_noise = 0
var g_uses_regex = 0
var g_uses_sqlite = 0
var g_uses_crypto = 0
var g_uses_xeddsa = 0
var g_uses_tls = 0
var g_uses_wss = 0

func reset_features() {
    g_uses_math = 0  g_uses_noise = 0  g_uses_regex = 0  g_uses_sqlite = 0
    g_uses_crypto = 0  g_uses_xeddsa = 0  g_uses_tls = 0  g_uses_wss = 0
}

func is_crypto_builtin(name) (b) {
    b = 0
    if name == "rand_bytes" || name == "sha256_bytes" || name == "sha1_bytes" || name == "hmac_sha256_bytes" || name == "hkdf_sha256" || name == "pbkdf2_sha256" { b = 1  return b }
    if name == "x25519_pub" || name == "x25519_shared" || name == "ed25519_pub" || name == "ed25519_sign" || name == "ed25519_verify" { b = 1  return b }
    if name == "aes_gcm_encrypt" || name == "aes_gcm_decrypt" || name == "aes_cbc_encrypt" || name == "aes_cbc_decrypt" { b = 1  return b }
    // NB: sha256/hmac_sha256 (string variants -> mfl_sha256/mfl_hmac_sha256) are in the
    // CORE prelude and do NOT set usesCrypto — only the *_bytes/asymmetric/aes ones do.
}

// note_feature: classify a builtin call by feature family and set the flag.
func note_feature(name) {
    if is_math1(name) || name == "pow" || name == "pi" || name == "f64_bits" || name == "f64_from_bits" { g_uses_math = 1 }
    if name == "noise2" || name == "noise3" { g_uses_noise = 1 }
    if name == "regex_match" || name == "regex_find" || name == "regex_replace" || name == "regex_groups" { g_uses_regex = 1 }
    if name == "sqlite_open" || name == "sqlite_close" || name == "sqlite_exec" || name == "sqlite_query" { g_uses_sqlite = 1 }
    if is_crypto_builtin(name) == 1 { g_uses_crypto = 1 }
    if name == "xeddsa_sign" || name == "xeddsa_verify" { g_uses_xeddsa = 1 }
    if name == "https_get" || name == "https_post" || name == "http_get" || name == "http_request" { g_uses_tls = 1 }
    if name == "wss_open" || name == "wss_send" || name == "wss_recv" || name == "wss_send_bin" || name == "wss_recv_bin" || name == "wss_close" { g_uses_wss = 1 }
}

func is_math1(name) (b) {
    b = name == "sin" || name == "cos" || name == "tan" || name == "asin" || name == "acos" || name == "atan" || name == "exp" || name == "log" || name == "log2" || name == "log10" || name == "sqrt" || name == "cbrt" || name == "floor" || name == "ceil" || name == "round" || name == "trunc" || name == "abs"
}

// builtin_cfn maps a builtin to its plain C function name (arg-forwarding form
// mfl_<cfn>(<args>)). "" => not a plain-table builtin (needs special handling).
func builtin_cfn(name) (s) {
    if name == "bytes" { s = "mfl_bytes_from_str"  return s }
    if name == "bytes_str" { s = "mfl_bytes_str"  return s }
    if name == "to_hex" { s = "mfl_bytes_hex"  return s }
    if name == "from_hex" { s = "mfl_bytes_unhex"  return s }
    if name == "byte_at" { s = "mfl_byte_at"  return s }
    if name == "bytes_sub" { s = "mfl_bytes_sub"  return s }
    if name == "bytes_index" { s = "mfl_bytes_index"  return s }
    if name == "bytes_concat" { s = "mfl_bytes_concat"  return s }
    if name == "rand_bytes" { s = "mfl_crypto_rand"  return s }
    if name == "sha256_bytes" { s = "mfl_crypto_sha256"  return s }
    if name == "sha1_bytes" { s = "mfl_crypto_sha1"  return s }
    if name == "hmac_sha256_bytes" { s = "mfl_crypto_hmac256"  return s }
    if name == "hkdf_sha256" { s = "mfl_crypto_hkdf"  return s }
    if name == "pbkdf2_sha256" { s = "mfl_crypto_pbkdf2"  return s }
    if name == "x25519_pub" { s = "mfl_crypto_x25519_pub"  return s }
    if name == "x25519_shared" { s = "mfl_crypto_x25519_shared"  return s }
    if name == "ed25519_pub" { s = "mfl_crypto_ed25519_pub"  return s }
    if name == "ed25519_sign" { s = "mfl_crypto_ed25519_sign"  return s }
    if name == "ed25519_verify" { s = "mfl_crypto_ed25519_verify"  return s }
    if name == "aes_gcm_encrypt" { s = "mfl_crypto_aes_gcm_enc"  return s }
    if name == "aes_gcm_decrypt" { s = "mfl_crypto_aes_gcm_dec"  return s }
    if name == "aes_cbc_encrypt" { s = "mfl_crypto_aes_cbc_enc"  return s }
    if name == "aes_cbc_decrypt" { s = "mfl_crypto_aes_cbc_dec"  return s }
    if name == "xeddsa_sign" { s = "mfl_xeddsa" + "_sign"  return s }
    if name == "xeddsa_verify" { s = "mfl_xeddsa" + "_verify"  return s }
    if name == "keys" { s = "mfl_map_keys"  return s }
    if name == "http_body" { s = "mfl_http_body"  return s }
    if name == "to_upper" { s = "mfl_to_upper"  return s }
    if name == "to_lower" { s = "mfl_to_lower"  return s }
    if name == "trim" { s = "mfl_trim"  return s }
    if name == "contains" { s = "mfl_contains"  return s }
    if name == "has_prefix" { s = "mfl_has_prefix"  return s }
    if name == "has_suffix" { s = "mfl_has_suffix"  return s }
    if name == "index" { s = "mfl_index"  return s }
    if name == "substr" { s = "mfl_substr"  return s }
    if name == "charat" { s = "mfl_charat"  return s }
    if name == "replace" { s = "mfl_replace"  return s }
    if name == "split" { s = "mfl_split"  return s }
    if name == "join" { s = "mfl_join"  return s }
    if name == "sleep" { s = "mfl_sleep"  return s }
    if name == "exit" { s = "mfl_exit"  return s }
    if name == "flush" { s = "mfl_flush"  return s }
    if name == "raw_mode" { s = "mfl_raw_mode"  return s }
    if name == "read_key" { s = "mfl_read_key"  return s }
    if name == "base64_encode" { s = "mfl_base64_encode"  return s }
    if name == "base64_decode" { s = "mfl_base64_decode"  return s }
    if name == "base64_encode_bytes" { s = "mfl_base64_encode_bytes"  return s }
    if name == "base64_decode_bytes" { s = "mfl_base64_decode_bytes"  return s }
    if name == "url_encode" { s = "mfl_url_encode"  return s }
    if name == "url_decode" { s = "mfl_url_decode"  return s }
    if name == "sha256" { s = "mfl_sha256"  return s }
    if name == "hmac_sha256" { s = "mfl_hmac_sha256"  return s }
    if name == "sqlite_open" { s = "mfl_sqlite_open"  return s }
    if name == "sqlite_close" { s = "mfl_sqlite_close"  return s }
    if name == "regex_match" { s = "mfl_regex_match"  return s }
    if name == "regex_find" { s = "mfl_regex_find"  return s }
    if name == "regex_replace" { s = "mfl_regex_replace"  return s }
    if name == "regex_groups" { s = "mfl_regex_groups"  return s }
    if name == "alloc" { s = "mfl_raw_alloc"  return s }
    if name == "free" { s = "mfl_raw_free"  return s }
    if name == "poke_f32" { s = "mfl_poke_f32"  return s }
    if name == "poke_i32" { s = "mfl_poke_i32"  return s }
    if name == "poke_u8" { s = "mfl_poke_u8"  return s }
    if name == "poke_u16" { s = "mfl_poke_u16"  return s }
