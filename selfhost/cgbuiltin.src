    if name == "wss_close" { s = "mfl_wss_close"  return s }
    if name == "pi" { s = "mfl_math_pi"  return s }
    s = ""
}

// cg_builtin emits the C for a builtin call. `names` are the already-evaluated args.
func cg_builtin(iid, call_idx, callee, names) (out) {
    argn := nodes[call_idx].kids
    note_feature(callee)   // flag the feature family for prelude gating
    if callee == "len" {
        k := node_kind(iid, argn[0])
        if k == 7 || k == 12 { out = "((" + names[0] + ").len)"  return out }
        if k == 10 { out = "mfl_map_len(" + names[0] + ")"  return out }
        out = "((int64_t)strlen(" + names[0] + "))"
        return out
    }
    if callee == "str" {
        k := node_kind(iid, argn[0])
        if k == 3 { out = "mfl_str_d(" + names[0] + ")"  return out }
        if k == 4 { out = "mfl_str_b(" + names[0] + ")"  return out }
        if k == 5 { out = names[0]  return out }
        out = "mfl_str_i(" + names[0] + ")"
        return out
    }
    if callee == "int" { out = "((int64_t)(" + names[0] + "))"  return out }
    if callee == "float" { out = "((double)(" + names[0] + "))"  return out }
    if callee == "f64_bits" { out = "mfl_f64_bits((double)(" + names[0] + "))"  return out }
    if callee == "f64_from_bits" { out = "mfl_f64_from_bits((int64_t)(" + names[0] + "))"  return out }
    if callee == "close" {
        if node_kind(iid, argn[0]) == 9 { out = "mfl_chan_close(" + names[0] + ")"  return out }
        out = "mfl_close(" + names[0] + ")"
        return out
    }
    if callee == "has" { ik, sk := map_key_args(iid, argn[0], names[1])  out = "mfl_map_has(" + names[0] + ", " + ik + ", " + sk + ")"  return out }
    if callee == "delete" { ik, sk := map_key_args(iid, argn[0], names[1])  out = "mfl_map_del(" + names[0] + ", " + ik + ", " + sk + ")"  return out }
    if callee == "append" {
        ct := elem_ctype(iid, argn[0])
        out = "mfl_append(" + names[0] + ", &((" + ct + "[1]){" + names[1] + "})[0], sizeof(" + ct + "))"
        return out
    }
    if callee == "sqlite_exec" {
        if len(names) == 3 { out = "mfl_sqlite_exec_p(" + join(names, ", ") + ")" } else { out = "mfl_sqlite_exec(" + join(names, ", ") + ")" }
        return out
    }
    if callee == "sqlite_query" {
        if len(names) == 3 { out = "mfl_sqlite_query_p(" + join(names, ", ") + ")" } else { out = "mfl_sqlite_query(" + join(names, ", ") + ")" }
        return out
    }
    if is_math1(callee) {
        fn := callee
        if fn == "abs" { fn = "fabs" }
        out = "mfl_math_" + fn + "((double)(" + names[0] + "))"
        return out
    }
    if callee == "pow" || callee == "atan2" || callee == "fmod" || callee == "hypot" {
        out = "mfl_math_" + callee + "((double)(" + names[0] + "), (double)(" + names[1] + "))"
        return out
    }
    if callee == "noise2" { out = "mfl_noise2((double)(" + names[0] + "), (double)(" + names[1] + "))"  return out }
    if callee == "noise3" { out = "mfl_noise3((double)(" + names[0] + "), (double)(" + names[1] + "), (double)(" + names[2] + "))"  return out }
    if callee == "json" || callee == "parse" { g_cg_unsup = 1  out = "0"  return out }
    cfn := builtin_cfn(callee)
    if cfn != "" { out = cfn + "(" + join(names, ", ") + ")"  return out }
    g_cg_unsup = 1   // extern FFI call / unknown -> slice 4d
    out = "0"
}

// cg_print emits println/print (one print per arg, single-space separators). The
// first line's indent was already emitted by the caller.
func cg_print(iid, call_idx, depth) {
    n := nodes[call_idx]
    args := n.kids
    i := 0
    for i < len(args) {
        if i > 0 { cemit("fputs(\" \", stdout); ") }
        e := cg_expr(iid, args[i])
        pk := node_kind(iid, args[i])
        if pk == 2 { cemit("printf(\"%lld\", (long long)(" + e + "));") } else {
        if pk == 3 { cemit("printf(\"%g\", (double)(" + e + "));") } else {
        if pk == 4 { cemit("fputs((" + e + ") ? \"true\" : \"false\", stdout);") } else {
        if pk == 5 { cemit("{ const char* _s = (" + e + "); fputs(_s ? _s : \"\", stdout); }") } else {
        if pk == 12 { cemit("fputs(mfl_bytes_hex(" + e + "), stdout);") } else {
            cemit("printf(\"%lld\", (long long)(" + e + "));")
        }}}}}
        cemit("\n")
        if i < len(args) - 1 { indent(depth) }
        i = i + 1
    }
    indent(depth)
    if n.s == "println" { cemit("fputs(\"\\n\", stdout);\n") } else { cemit("fflush(stdout);\n") }
}

func assign_line(iid, name, val, depth) {
    if name == "_" { return }
    indent(depth + 1)
    cemit(var_ref(iid, name) + " = " + val + ";\n")
}

// mrb_info: multi-return builtin -> (C fn, result struct type, comma-joined fields).
// "" cfn => not a multi-return builtin. (needsTLS only gates the skipped prelude.)
func mrb_info(name) (cfn, ctype, fields) {
    cfn = ""
    ctype = ""
    fields = ""
    if name == "http_get" { cfn = "mfl_http_get"  ctype = "mfl_http_result"  fields = "status,body,err"  return cfn, ctype, fields }
    if name == "http_request" { cfn = "mfl_http_request"  ctype = "mfl_http_result"  fields = "status,body,err"  return cfn, ctype, fields }
    if name == "json_get" { cfn = "mfl_json_get"  ctype = "mfl_json_result"  fields = "value,err"  return cfn, ctype, fields }
    if name == "exec" { cfn = "mfl_exec"  ctype = "mfl_exec_result"  fields = "code,out,err"  return cfn, ctype, fields }
    if name == "mmap_file" { cfn = "mfl_mmap_file"  ctype = "mfl_mmap_result"  fields = "ptr,len"  return cfn, ctype, fields }
}

func callee_inst_of(iid, idx) (ci) {
    ins := g_insts[iid]
    j := 0
    for j < len(ins.cnodes) { if ins.cnodes[j] == idx { ci = ins.cinsts[j]  return ci }  j = j + 1 }
    ci = -1
}

// cg_multi_assign emits `a, b := rhs` (port of multiAssign): user multi-return call
// destructuring, parallel assignment, or a single value. comma-ok recv + multi-return
// builtins are deferred (g_cg_unsup). The caller already emitted the leading indent.
func cg_multi_assign(iid, idx, depth) {
    n := nodes[idx]
    if len(n.kids) == 1 {
        rhs0 := n.kids[0]
        rn := nodes[rhs0]
        if rn.kind == K_CALL && func_root(rn.s) >= 0 {
            cinst := callee_inst_of(iid, rhs0)
            if cinst >= 0 && len(g_insts[cinst].rslots) >= 2 {
                argstrs := []string{}
                for _, a := range rn.kids { argstrs = append(argstrs, cg_expr(iid, a)) }
                id := g_tmpid
                g_tmpid = g_tmpid + 1
                cn := g_insts[cinst].cname
                cemit("{\n")
                indent(depth + 1)
                cemit(cn + "_ret _t" + str(id) + " = " + cn + "(" + join(argstrs, ", ") + ");\n")
                i := 0
                for i < len(n.names) { assign_line(iid, n.names[i], "_t" + str(id) + ".r" + str(i), depth)  i = i + 1 }
                indent(depth)
                cemit("}\n")
                return
            }
        }
        if rn.kind == K_CALL && func_root(rn.s) < 0 {
            note_feature(rn.s)   // http_get/http_request set usesTLS (multi-return path)
            cfn, ctype, fstr := mrb_info(rn.s)
            if cfn != "" {
                fld := split(fstr, ",")
                argstrs := []string{}
                for _, a := range rn.kids { argstrs = append(argstrs, cg_expr(iid, a)) }
                id := g_tmpid
                g_tmpid = g_tmpid + 1
                cemit("{\n")
                indent(depth + 1)
                cemit(ctype + " _t" + str(id) + " = " + cfn + "(" + join(argstrs, ", ") + ");\n")
                i := 0
                for i < len(n.names) { assign_line(iid, n.names[i], "_t" + str(id) + "." + fld[i], depth)  i = i + 1 }
                indent(depth)
                cemit("}\n")
                return
            }
            g_cg_unsup = 1  cemit("0;\n")   // unknown multi-return builtin
            return
        }
        if rn.kind == K_RECV {
            cs := cg_expr(iid, rn.a)
            ect := elem_ctype(iid, rn.a)   // channel element C type
            id := g_tmpid
            g_tmpid = g_tmpid + 1
            ids := str(id)
            cemit("{\n")
            indent(depth + 1)
            cemit(ect + " _rv" + ids + "; int _rok" + ids + " = mfl_chan_recv2(" + cs + ", &_rv" + ids + ");\n")
            indent(depth + 1)
            cemit("if (!_rok" + ids + ") memset(&_rv" + ids + ", 0, sizeof(_rv" + ids + "));\n")
            assign_line(iid, n.names[0], "_rv" + ids, depth)
            assign_line(iid, n.names[1], "_rok" + ids, depth)
            indent(depth)
            cemit("}\n")
            return
        }
        cemit(var_ref(iid, n.names[0]) + " = " + cg_expr(iid, rhs0) + ";\n")
        return
    }
    // parallel assignment: hoist all RHS into temps, then assign
    id := g_tmpid
    g_tmpid = g_tmpid + 1
    cemit("{\n")
    i := 0
    for i < len(n.kids) {
        indent(depth + 1)
        cemit(node_ctype(iid, n.kids[i]) + " _t" + str(id) + "_" + str(i) + " = " + cg_expr(iid, n.kids[i]) + ";\n")
        i = i + 1
    }
    i = 0
    for i < len(n.names) { assign_line(iid, n.names[i], "_t" + str(id) + "_" + str(i), depth)  i = i + 1 }
    indent(depth)
    cemit("}\n")
}
