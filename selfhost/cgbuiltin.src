    if name == "read_file_bytes" { s = "mfl_read_file_bytes"  return s }
    if name == "write_bytes" { s = "mfl_write_bytes"  return s }
    if name == "write_file" { s = "mfl_write_file"  return s }
    if name == "write_file_bytes" { s = "mfl_write_file_bytes"  return s }
    if name == "remove" { s = "mfl_remove_file"  return s }
    if name == "list_dir" { s = "mfl_list_dir"  return s }
    if name == "system" { s = "mfl_system"  return s }
    if name == "mkdir" { s = "mfl_mkdir"  return s }
    if name == "https_get" { s = "mfl_https_get"  return s }
    if name == "https_post" { s = "mfl_https_post"  return s }
    if name == "wss_open" { s = "mfl_wss_open"  return s }
