// selfhost/cgprelude.src — the static C runtime prelude (cRuntime + netRuntime +
// ttyRuntime, the always-native base blocks), embedded as base64 and decoded at
// runtime. Lets the MFL compiler emit a COMPLETE C file (prelude + program) so it
// can build a native binary — the last piece for the self-hosting FIXPOINT.
// GENERATED from codegen.go's runtime constants via a trivial program's prelude;
// regenerate if the runtime changes. Covers programs using no math/crypto/sqlite/
// regex/noise/tls/wss builtins (which need extra gated blocks) — the compiler is one.
var CG_PRELUDE_B64 = ""
func emit_prelude() { cemit(base64_decode(CG_PRELUDE_B64)) }
